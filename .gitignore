# aimux runtime state & scratch (regenerated per session)
AIMemory/.aimux/
AIMemory/tmp/

# transient handoff/result artifacts from runs (keep the example only)
/AIMemory/handoff_*.md
!/AIMemory/handoff_example.md
/*_result.txt

# local, user-specific Claude Code settings (paths, permissions)
.claude/settings.local.json

# Python in-project virtual environment (deps pinned in requirements.txt)
.venv/

# OS / editor noise
.DS_Store
*.swp

# built distribution zips (regenerated by make-dist.sh; never committed)
dist/

# agent CLI local config created during runs (not part of the template)
.qwen/
.opencode/

# proprietary pptx skill — not committed (skills-lock.json pins the reference)
.claude/skills/pptx/

# per-install runtime state (repo pointer, user config)
.harness/

# python bytecode
__pycache__/
*.pyc

# redundant scaffold build artifacts (not project source)
make_Harness-latest.zip
make_Harness-v*-*/
